---
import Base from '../layouts/Base.astro';
import Nav from '../components/Nav.astro';
import Footer from '../components/Footer.astro';
import Services from '../components/Services.astro';
import NewStoresBanner from '../components/NewStoresBanner.astro';
import FeaturedTestimonials from '../components/FeaturedTestimonials.astro';
import CaseStudiesPreview from '../components/CaseStudiesPreview.astro';
import AboutSection from '../components/AboutSection.astro';
import CTA from '../components/CTA.astro';
import Hero from '../components/Hero.astro';
import { getPageMeta } from '../lib/content';

const meta = await getPageMeta('home');
---

<Base
  title={meta.title}
  description={meta.description}
  image={meta.image}
>
  <Nav />
  <main>
    <Hero />
    <Services />
    <NewStoresBanner />
    <FeaturedTestimonials />
    <CaseStudiesPreview />
    <AboutSection />
    <CTA />
  </main>
  <Footer />
</Base>
