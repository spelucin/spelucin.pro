---
import Base from '../../layouts/Base.astro';
import Nav from '../../components/Nav.astro';
import Footer from '../../components/Footer.astro';
import Eyebrow from '../../components/Eyebrow.astro';
import IconArrowRight from '../../components/IconArrowRight.astro';
import CTA from '../../components/CTA.astro';
import { rule } from '../../data';
import { getCaseStudies, getPageMeta } from '../../lib/content';

const meta = await getPageMeta('casos-de-estudio');
const caseStudies = await getCaseStudies();
---

<Base
  title={meta.title}
  description={meta.description}
  image={meta.image}
>
  <Nav />
  <main>
    <section style="padding-top: 10rem; padding-bottom: 4rem; background: #fff">
      <div class="max-w-5xl mx-auto px-6">
        <Eyebrow>Casos de estudio</Eyebrow>
        <h1 style="font-size: clamp(2.5rem, 5vw, 4rem); font-weight: 700; line-height: 1.05; letter-spacing: -0.04em; color: #0d1f3c; margin: 0.5rem 0 1.5rem; max-width: 16ch">
          Resultados reales,<br />tiendas reales.
        </h1>
        <p style="font-size: 1.1rem; line-height: 1.7; color: rgba(13,31,60,0.55); margin: 0; max-width: 48ch">
          Cada caso es una tienda Shopify real con un problema técnico específico. Sin proyecciones, sin datos ficticios.
        </p>
      </div>
    </section>

    <section style="background: #fff; padding: 0 0 5rem">
      <div class="max-w-5xl mx-auto px-6">
        <div style={{ ...rule, marginBottom: "3rem" }} />

        <div class="grid gap-6">
          {caseStudies.map((cs) => (
            <a href={`/casos-de-estudio/${cs.slug}/`} class="case-card" style="text-decoration: none; display: flex; flex-direction: row; border-radius: 1rem; border: 1px solid rgba(21,96,189,0.10); background: var(--color-surface); overflow: hidden; transition: transform 0.2s, box-shadow 0.2s">
              {cs.cover && (
                <img
                  src={cs.cover}
                  alt={cs.client}
                  class="case-card-image"
                  style="width: 260px; flex-shrink: 0; object-fit: cover; display: block"
                />
              )}
              <div style="padding: 1.5rem; display: flex; flex-direction: column; justify-content: center; flex: 1; min-width: 0">
                <h2 style="font-size: 1.15rem; font-weight: 700; color: #0d1f3c; letter-spacing: -0.025em; margin: 0 0 0.5rem; line-height: 1.25">
                  {cs.client}
                </h2>
                <p style="font-size: 0.875rem; color: rgba(13,31,60,0.55); line-height: 1.65; margin: 0 0 1.25rem">
                  {cs.shortDescription || cs.summary}
                </p>
                <div style="display: flex; gap: 1.75rem; padding-top: 1rem; border-top: 1px solid rgba(21,96,189,0.07)">
                  {cs.results.slice(0, 3).map((m) => (
                    <div>
                      <div style="font-size: 0.95rem; font-weight: 700; color: #1560bd; letter-spacing: -0.02em">{m.value}</div>
                      <div style="font-size: 0.68rem; color: rgba(13,31,60,0.45); margin-top: 0.1rem; line-height: 1.3">{m.label}</div>
                    </div>
                  ))}
                </div>
              </div>
            </a>
          ))}
        </div>
      </div>
    </section>

    <style is:global>
      .case-card:hover {
        transform: translateY(-3px);
        box-shadow: 0 8px 30px rgba(21,96,189,0.1);
      }
      .case-card-image {
        align-self: stretch;
        height: auto;
      }
      @media (max-width: 767px) {
        .case-card {
          flex-direction: column !important;
        }
        .case-card-image {
          width: 100% !important;
          aspect-ratio: 16 / 9;
        }
      }
    </style>

    <CTA
      id="cta"
      heading="¿Quieres resultados similares?"
      description="En 30 minutos evaluamos tu tienda y te decimos exactamente qué está frenando tu crecimiento orgánico."
      buttonText="Consulta gratuita"
    />
  </main>
  <Footer />
</Base>
