---
import Base from '../../layouts/Base.astro';
import Nav from '../../components/Nav.astro';
import Footer from '../../components/Footer.astro';
import IconArrowRight from '../../components/IconArrowRight.astro';
import IconCheck from '../../components/IconCheck.astro';
import CTA from '../../components/CTA.astro';
import { getCaseStudies } from '../../lib/content';
import type { CaseStudyWithSeo } from '../../lib/content';

export async function getStaticPaths() {
  const caseStudies = await getCaseStudies();
  return caseStudies.map(cs => ({
    params: { slug: cs.slug },
    props: { cs },
  }));
}

const { cs } = Astro.props as { cs: CaseStudyWithSeo };

const breadcrumbSchema = {
  "@context": "https://schema.org",
  "@type": "BreadcrumbList",
  itemListElement: [
    { "@type": "ListItem", position: 1, name: "Casos de estudio", item: "https://spelucin.pro/casos-de-estudio" },
    { "@type": "ListItem", position: 2, name: cs.headline, item: `https://spelucin.pro/casos-de-estudio/${cs.slug}` },
  ],
};

const articleSchema = {
  "@context": "https://schema.org",
  "@type": "Article",
  headline: cs.headline,
  description: cs.summary,
  about: cs.industry,
  author: { "@type": "Person", name: "Alex Spelucin" },
  publisher: { "@type": "ProfessionalService", name: "Alex Spelucin" },
};

const toolList = cs.tools ? cs.tools.split(",").map(t => t.trim()).filter(Boolean) : [];
---

<Base
  title={cs.seo.title || `${cs.headline} - Casos de estudio | Alex Spelucin`}
  description={cs.seo.description || cs.summary}
  image={cs.seo.image}
>
  <Fragment slot="schema">
    <script type="application/ld+json" set:html={JSON.stringify(breadcrumbSchema)} />
    <script type="application/ld+json" set:html={JSON.stringify(articleSchema)} />
  </Fragment>
  <Nav />
  <div>

    {/* ── Hero ──────────────────────────────────────────── */}
    <section style="background: #fff; padding-top: 10rem; padding-bottom: 3rem; border-bottom: 1px solid rgba(21,96,189,0.08)">
      <div class="max-w-5xl mx-auto px-6 reveal">
        <a
          href="/casos-de-estudio/"
          style="display: inline-flex; align-items: center; gap: 0.4rem; font-size: 0.82rem; color: rgba(21,96,189,0.55); text-decoration: none; margin-bottom: 2rem; font-weight: 500"
        >
          <span style="transform: rotate(180deg); display: inline-block"><IconArrowRight /></span> Casos de estudio
        </a>

        <h1 style="font-size: clamp(2rem, 5vw, 3rem); font-weight: 700; letter-spacing: -0.03em; color: #0d1f3c; margin: 0 0 0.75rem; line-height: 1.08; max-width: 28ch">
          {cs.headline}
        </h1>
        <p style="font-size: 1.05rem; color: rgba(13,31,60,0.5); line-height: 1.7; margin: 0 0 2rem; max-width: 65ch">
          {cs.summary}
        </p>

        {cs.cover && (
          <img
            src={cs.cover}
            alt={cs.headline}
            style="width: 100%; aspect-ratio: 2/1; object-fit: cover; border-radius: 0.75rem; display: block"
          />
        )}
      </div>
    </section>

    {/* ── La tienda ─────────────────────────────────────── */}
    <section style="background: #fff; padding: 3rem 0; border-bottom: 1px solid rgba(21,96,189,0.08)">
      <div class="max-w-5xl mx-auto px-6 reveal">
        <h2 style="font-size: clamp(1.35rem, 3vw, 1.75rem); font-weight: 700; letter-spacing: -0.03em; color: #0d1f3c; margin: 0 0 1.5rem; line-height: 1.2">
          La tienda
        </h2>
        <div style="display: flex; flex-direction: column; gap: 0.5rem">
          {[
            ["Cliente", cs.client],
            ["Plataforma", cs.platform],
            ["Industria", cs.industry],
            ["Mercado", cs.market],
            ["Duración", cs.timeline],
            ["Rol", cs.role],
            ...(cs.team ? [["Equipo", cs.team]] : []),
          ].map(([k, v]) => (
            <div style="display: flex; gap: 0.75rem">
              <span style="font-size: 0.8rem; font-weight: 600; color: rgba(13,31,60,0.4); flex-shrink: 0; min-width: 80px; padding-top: 0.05rem">{k}</span>
              <span style="font-size: 0.85rem; color: rgba(13,31,60,0.75); line-height: 1.5">{v}</span>
            </div>
          ))}
        </div>
      </div>
    </section>

    {/* ── El desafío ────────────────────────────────────── */}
    <section style="background: #fff; padding: 3rem 0; border-bottom: 1px solid rgba(21,96,189,0.08)">
      <div class="max-w-5xl mx-auto px-6 reveal">
        <h2 style="font-size: clamp(1.35rem, 3vw, 1.75rem); font-weight: 700; letter-spacing: -0.03em; color: #0d1f3c; margin: 0 0 1rem; line-height: 1.2">
          El desafío
        </h2>
        <p style="font-size: 0.95rem; color: rgba(13,31,60,0.65); line-height: 1.75; margin: 0; max-width: 65ch">
          {cs.challenge}
        </p>
      </div>
    </section>

    {/* ── Qué hice ──────────────────────────────────────── */}
    <section style="background: #fff; padding: 3rem 0; border-bottom: 1px solid rgba(21,96,189,0.08)">
      <div class="max-w-5xl mx-auto px-6 reveal">
        <h2 style="font-size: clamp(1.35rem, 3vw, 1.75rem); font-weight: 700; letter-spacing: -0.03em; color: #0d1f3c; margin: 0 0 1.5rem; line-height: 1.2">
          Qué hice
        </h2>
        <ul style="list-style: none; margin: 0; padding: 0; display: flex; flex-direction: column; gap: 0.5rem">
          {cs.whatIdid.map(item => (
            <li style="display: flex; gap: 0.6rem; font-size: 0.9rem; color: rgba(13,31,60,0.65); line-height: 1.6">
              <span style="color: #1560bd; flex-shrink: 0; margin-top: 0.15rem"><IconCheck /></span>
              {item}
            </li>
          ))}
        </ul>
      </div>
    </section>

    {/* ── Resultados ────────────────────────────────────── */}
    <section style="background: #fff; padding: 3rem 0; border-bottom: 1px solid rgba(21,96,189,0.08)">
      <div class="max-w-5xl mx-auto px-6 reveal">
        <h2 style="font-size: clamp(1.35rem, 3vw, 1.75rem); font-weight: 700; letter-spacing: -0.03em; color: #0d1f3c; margin: 0 0 1.5rem; line-height: 1.2">
          Resultados
        </h2>
        <div class="grid" style="grid-template-columns: repeat(auto-fit, minmax(180px, 1fr)); gap: 1.5rem">
          {cs.results.map(r => (
            <div>
              <div style="font-size: clamp(1.75rem, 4vw, 2.25rem); font-weight: 700; color: #1560bd; letter-spacing: -0.03em; line-height: 1">
                {r.value}
              </div>
              <div style="font-size: 0.82rem; color: rgba(13,31,60,0.5); margin-top: 0.35rem; line-height: 1.4">{r.label}</div>
            </div>
          ))}
        </div>
      </div>
    </section>

    {/* ── Por qué funcionó ──────────────────────────────── */}
    <section style="background: #fff; padding: 3rem 0; border-bottom: 1px solid rgba(21,96,189,0.08)">
      <div class="max-w-5xl mx-auto px-6 reveal">
        <h2 style="font-size: clamp(1.35rem, 3vw, 1.75rem); font-weight: 700; letter-spacing: -0.03em; color: #0d1f3c; margin: 0 0 1rem; line-height: 1.2">
          Por qué funcionó
        </h2>
        <p style="font-size: 0.95rem; color: rgba(13,31,60,0.65); line-height: 1.75; margin: 0; max-width: 65ch">
          {cs.whyItWorked}
        </p>
      </div>
    </section>

    {/* ── Herramientas ──────────────────────────────────── */}
    {toolList.length > 0 && (
      <section style="background: #fff; padding: 3rem 0; border-bottom: 1px solid rgba(21,96,189,0.08)">
        <div class="max-w-5xl mx-auto px-6 reveal">
          <h2 style="font-size: clamp(1.35rem, 3vw, 1.75rem); font-weight: 700; letter-spacing: -0.03em; color: #0d1f3c; margin: 0 0 0.75rem; line-height: 1.2">
            Herramientas
          </h2>
          <div style="display: flex; flex-wrap: wrap; gap: 0.5rem">
            {toolList.map(tool => (
              <span style="font-size: 0.82rem; font-weight: 500; color: rgba(21,96,189,0.7); background: rgba(21,96,189,0.08); padding: 0.3rem 0.85rem; border-radius: 100px">
                {tool}
              </span>
            ))}
          </div>
        </div>
      </section>
    )}

    {/* ── CTA ───────────────────────────────────────────── */}
    <CTA
      id="cta"
      heading="¿Quieres resultados similares?"
      description="Si tu sitio tiene tráfico pero no lo convierte en resultados de negocio, identifiquemos qué lo está frenando y construyamos una hoja de ruta enfocada en crecimiento medible."
      buttonText="Agendar llamada"
      buttonHref="/contacto/"
    />

  </div>
  <Footer />
</Base>
