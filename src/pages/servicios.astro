---
import Base from '../layouts/Base.astro';
import Nav from '../components/Nav.astro';
import Footer from '../components/Footer.astro';
import CTA from '../components/CTA.astro';
import IconArrowRight from '../components/IconArrowRight.astro';
import Eyebrow from '../components/Eyebrow.astro';
import Testimonials from '../components/Testimonials.astro';
import IconAudit from '../components/IconAudit.astro';
import IconCatalog from '../components/IconCatalog.astro';
import IconWorkshop from '../components/IconWorkshop.astro';
import IconCheck from '../components/IconCheck.astro';
import { services, rule } from '../data';
import Terminal from '../components/Terminal.astro';

const allFaqs = services.flatMap(s => s.detail.faq.map(f => ({ ...f, service: s.name })));
const icons = [IconAudit, IconCatalog, IconWorkshop];

const faqSchema = {
  "@context": "https://schema.org",
  "@type": "FAQPage",
  mainEntity: allFaqs.map(f => ({
    "@type": "Question",
    name: f.question,
    acceptedAnswer: { "@type": "Answer", text: f.answer },
  })),
};
---

<Base
  title="Servicios de SEO técnico para Shopify - Alex Spelucin"
  description="Auditoría SEO técnica, estrategia de catálogo y talleres a medida para tiendas Shopify. Sin paquetes genéricos, sin retainer mensual."
  image="/og/servicios.jpg"
>
  <script slot="schema" type="application/ld+json" set:html={JSON.stringify(faqSchema)} />
  <Nav />
  <main>
    <section style="padding-top: 10rem; padding-bottom: 4rem; background: #fff">
      <div class="max-w-5xl mx-auto px-6">
        <h1 style="font-size: clamp(2.5rem, 5vw, 4rem); font-weight: 700; line-height: 1.05; letter-spacing: -0.04em; color: #0d1f3c; margin: 0 0 1.5rem; max-width: 20ch">
          Especialista en SEO para Shopify
        </h1>
        <p style="font-size: 1.1rem; line-height: 1.7; color: rgba(13,31,60,0.55); margin: 0; max-width: 52ch">
          Tres servicios con alcance definido, entregables claros y resultados medibles. Sin paquetes genéricos, sin retainer mensual.
        </p>
      </div>
    </section>

    <section id="servicios" style="background: #fff; padding: 0 0 5rem">
      <div class="max-w-5xl mx-auto px-6 reveal">

        <div style={rule} />

        <div class="grid md:grid-cols-3 gap-6" style="padding-top: 3rem">
          {services.map((s, i) => (
            <a href={`/servicios/${s.slug}/`} class="service-card" style="text-decoration: none; display: flex; flex-direction: column; border-radius: 1rem; padding: 2rem; border: 1px solid rgba(21,96,189,0.10); background: #f8fbff; transition: transform 0.2s, box-shadow 0.2s">
              <div style="margin-bottom: 1.25rem">
                {icons[i] && (() => { const Icon = icons[i]; return <Icon size={28} />; })()}
              </div>
              <div style="font-size: 0.72rem; font-weight: 700; color: #1560bd; letter-spacing: 0.05em; text-transform: uppercase; margin-bottom: 0.35rem">{s.price}</div>
              <h2 style="font-size: 1.15rem; font-weight: 700; color: #0d1f3c; letter-spacing: -0.025em; margin: 0 0 0.75rem; line-height: 1.25">{s.name}</h2>
              <p style="font-size: 0.875rem; color: rgba(13,31,60,0.55); line-height: 1.65; margin: 0 0 1.5rem; flex: 1">{s.description}</p>
              <div style="display: flex; flex-direction: column; gap: 0; margin-bottom: 1.5rem">
                {s.deliverables.slice(0, 3).map((d) => (
                  <div style="display: flex; align-items: flex-start; gap: 0.5rem; padding: 0.4rem 0">
                    <span style="flex-shrink: 0; margin-top: 0.1rem"><IconCheck /></span>
                    <span style="font-size: 0.8rem; color: rgba(13,31,60,0.6); line-height: 1.4; font-weight: 500">{d}</span>
                  </div>
                ))}
              </div>
              <span style="display: inline-flex; align-items: center; gap: 0.4rem; font-size: 0.82rem; font-weight: 600; color: #1560bd">
                Ver detalle <IconArrowRight />
              </span>
            </a>
          ))}
        </div>

      </div>
    </section>

    {/* ── CLI animation (floating, full content width) ───────── */}
    <section style="background: #fff; padding: 2.5rem 0 1.5rem">
      <div class="max-w-5xl mx-auto px-6">
        <Terminal title="zsh - shopify-seo" fullwidth>
          <div class="terminal-body">
            <p class="term-line term-delay-1"><span class="term-prompt">$</span> opencode audit --site=gunplastore.mx --crawl</p>
            <p class="term-line term-delay-2"><span class="term-spinner"></span> Inicializando crawler de Shopify...</p>
            <p class="term-line term-delay-3"><span class="term-bar">[██████████████████████]</span> <span class="term-pct">100%</span></p>
            <p class="term-line term-delay-4"><span class="term-warning">[warning]</span> 142 páginas de tag duplicadas detectadas</p>
            <p class="term-line term-delay-5"><span class="term-success">[success]</span> Core Web Vitals audit: LCP 2.1s · CLS 0.02</p>
            <p class="term-line term-delay-6"><span class="term-prompt">$</span> opencode catalog --vertical="model-kits" --cluster</p>
            <p class="term-line term-delay-7"><span class="term-spinner"></span> Agrupando intención de búsqueda...</p>
            <p class="term-line term-delay-8"><span class="term-success">[success]</span> Jerarquía de 3 niveles generada · 248 colecciones</p>
            <p class="term-line term-delay-9"><span class="term-info">[info]</span> Facetas de filtro mapeadas a plantillas URL</p>
            <p class="term-line term-delay-10"><span class="term-prompt">$</span> opencode training --team="marketing" --lab</p>
            <p class="term-line term-delay-11"><span class="term-spinner"></span> Preparando sandbox de GA4 + GSC...</p>
            <p class="term-line term-delay-12"><span class="term-success">[success]</span> Espacio de entrenamiento del equipo listo</p>
            <p class="term-line term-delay-13"><span class="term-success">[success]</span> Propuesta de alcance enviada.</p>
          </div>
        </Terminal>
      </div>
    </section>

    <Testimonials paddingTop="1.5rem" />

    <section style="background: #fff; padding: 4rem 0">
      <div class="max-w-5xl mx-auto px-6">
        <div style={rule} />
        <h2 style="font-size: clamp(1.5rem, 3vw, 2rem); font-weight: 700; letter-spacing: -0.04em; color: #0d1f3c; margin: 3rem 0 2rem; line-height: 1.2">Preguntas frecuentes</h2>
        <div style="display: flex; flex-direction: column; gap: 0">
          {allFaqs.map((faq, i) => (
            <>
              {i > 0 && <div style="height: 1px; background: rgba(21,96,189,0.07)" />}
              <div style="padding: 1.25rem 0">
                <div style="font-size: 0.95rem; font-weight: 600; color: #0d1f3c; line-height: 1.4; margin-bottom: 0.5rem">{faq.question}</div>
                <p style="font-size: 0.9rem; line-height: 1.7; color: rgba(13,31,60,0.55); margin: 0">{faq.answer}</p>
              </div>
            </>
          ))}
        </div>
      </div>
    </section>

    <CTA
      id="cta"
      heading="¿No sabes cuál servicio necesitas?"
      description="En 30 minutos evaluamos tu situación y te recomendamos el camino con mayor impacto."
      buttonText="Consulta gratuita"
    />
  </main>
  <Footer />
</Base>
