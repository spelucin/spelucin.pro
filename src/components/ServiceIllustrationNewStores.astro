  <rect x="180" y="197.5" width="42" height="4" rx="1.5" fill="rgba(13,31,60,0.25)" />

  <circle cx="172" cy="214" r="4" fill="rgba(39,201,63,0.15)" />
  <path d="M170 214 l1.5 1.5 l3-3" stroke="#22a06b" stroke-width="1.2" fill="none" stroke-linecap="round" stroke-linejoin="round" />
  <rect x="180" y="211.5" width="56" height="4" rx="1.5" fill="rgba(13,31,60,0.25)" />
