---
// Pack Tiendas Nuevas: browser with sidebar nav + product cards + SEO indicator.
---
<svg viewBox="0 0 320 280" xmlns="http://www.w3.org/2000/svg" style="width: 100%; height: auto; display: block">
  <defs>
    <linearGradient id="nsGrad" x1="0" y1="0" x2="1" y2="1">
      <stop offset="0%" stop-color="#1560bd" stop-opacity="0.06" />
      <stop offset="100%" stop-color="#7c3aed" stop-opacity="0.04" />
    </linearGradient>
    <linearGradient id="nsBar" x1="0" y1="0" x2="0" y2="1">
      <stop offset="0%" stop-color="#f8fbff" />
      <stop offset="100%" stop-color="#f0f6ff" />
    </linearGradient>
  </defs>

  {/* Browser frame */}
  <rect x="10" y="8" width="300" height="220" rx="10" fill="#fff" stroke="rgba(21,96,189,0.18)" stroke-width="1.5" />
  <rect x="10" y="8" width="300" height="34" rx="10" fill="url(#nsBar)" />
  <rect x="10" y="32" width="300" height="10" fill="url(#nsBar)" />

  {/* Traffic lights */}
  <circle cx="28" cy="25" r="4" fill="rgba(255,95,87,0.7)" />
  <circle cx="42" cy="25" r="4" fill="rgba(255,189,46,0.7)" />
  <circle cx="56" cy="25" r="4" fill="rgba(39,201,63,0.7)" />

