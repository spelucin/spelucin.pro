  <rect x="18" y="52" width="52" height="7" rx="2" fill="rgba(21,96,189,0.18)" />
  <rect x="18" y="66" width="44" height="5" rx="1.5" fill="rgba(21,96,189,0.08)" />
  <rect x="18" y="78" width="48" height="5" rx="1.5" fill="rgba(21,96,189,0.12)" />
  <rect x="18" y="90" width="40" height="5" rx="1.5" fill="rgba(21,96,189,0.08)" />
  <rect x="18" y="102" width="46" height="5" rx="1.5" fill="rgba(21,96,189,0.08)" />
  <rect x="18" y="114" width="38" height="5" rx="1.5" fill="rgba(21,96,189,0.08)" />

