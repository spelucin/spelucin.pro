  <circle cx="22" cy="68.5" r="1.5" fill="rgba(21,96,189,0.15)" />
  <circle cx="22" cy="80.5" r="1.5" fill="#1560bd" />
  <circle cx="22" cy="92.5" r="1.5" fill="rgba(21,96,189,0.15)" />
  <circle cx="22" cy="104.5" r="1.5" fill="rgba(21,96,189,0.15)" />
  <circle cx="22" cy="116.5" r="1.5" fill="rgba(21,96,189,0.15)" />

