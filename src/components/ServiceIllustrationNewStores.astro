  <rect x="230" y="84" width="62" height="52" rx="5" fill="rgba(21,96,189,0.05)" stroke="rgba(21,96,189,0.08)" stroke-width="0.8" />
  <rect x="230" y="84" width="62" height="28" rx="5" fill="rgba(21,96,189,0.08)" />
  <rect x="236" y="88" width="22" height="10" rx="3" fill="#22a06b" />
