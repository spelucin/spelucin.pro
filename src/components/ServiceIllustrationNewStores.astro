  <rect x="72" y="17" width="200" height="16" rx="8" fill="rgba(21,96,189,0.06)" stroke="rgba(21,96,189,0.10)" stroke-width="0.8" />
  <text x="82" y="28.5" font-family="DM Sans, sans-serif" font-size="8" fill="rgba(21,96,189,0.45)" font-weight="500">tu-tienda.mx/collections</text>

  {/* Divider */}
  <line x1="10" y1="42" x2="310" y2="42" stroke="rgba(21,96,189,0.10)" stroke-width="1" />

  {/* Sidebar */}
  <rect x="10" y="42" width="72" height="186" fill="rgba(21,96,189,0.02)" />
  <line x1="82" y1="42" x2="82" y2="228" stroke="rgba(21,96,189,0.08)" stroke-width="1" />

