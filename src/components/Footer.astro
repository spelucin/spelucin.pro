---
import Logo from './Logo.astro';
---

<footer style="border-top: 1px solid rgba(21,96,189,0.10); background: #f4fdff; padding: 2rem 0">
  <div class="max-w-5xl mx-auto px-6 flex flex-wrap items-center justify-between gap-4">
    <div style="display: flex; align-items: center; gap: 0.6rem">
      <Logo size={22} />
      <span style="font-size: 0.78rem; color: rgba(21,96,189,0.4)">SEO técnico para Shopify</span>
    </div>
    <div style="display: flex; gap: 1.5rem; align-items: center">
      <a href="mailto:alex@spelucin.pro" style="font-size: 0.8rem; color: rgba(21,96,189,0.5); text-decoration: none; transition: color 0.15s">
        alex@spelucin.pro
      </a>
      <a href="https://linkedin.com/in/spelucin" target="_blank" rel="noopener noreferrer" style="font-size: 0.8rem; color: rgba(21,96,189,0.5); text-decoration: none; transition: color 0.15s">
        LinkedIn
      </a>
      <span style="font-size: 0.78rem; color: rgba(21,96,189,0.35)">© 2025</span>
    </div>
  </div>
</footer>
