---
import Logo from './Logo.astro';
---

<footer style="border-top: 1px solid rgba(21,96,189,0.10); background: #f4fdff; padding: 2rem 0">
  <div class="max-w-5xl mx-auto px-6 flex flex-wrap items-center justify-between gap-4">
    <div style="display: flex; align-items: center; gap: 0.6rem">
      <Logo size={22} />
      <span style="font-size: 0.78rem; color: rgba(21,96,189,0.4)">SEO técnico para Shopify</span>
    </div>
    <div style="display: flex; gap: 1.5rem; align-items: center">
      <a href="/politica-de-privacidad/" style="font-size: 0.78rem; color: rgba(21,96,189,0.4); text-decoration: none; transition: color 0.15s">Política de privacidad</a>
      <span style="font-size: 0.78rem; color: rgba(21,96,189,0.35)">Derechos reservados - 2026</span>
    </div>
  </div>
</footer>
