---
import Eyebrow from './Eyebrow.astro';
import { rule } from '../data';

const testimonials = [
  {
    quote:
      'Alex es un excelente profesional con un extenso conocimiento a nivel técnico. Se capacita constantemente en SEO y en temas de tecnología complementarios a este, logrando intersecciones de conocimiento fascinantes sin perder el foco en el crecimiento del negocio y los objetivos del cliente.',
    name: 'Darío Vergara',
    role: 'SEO Lead en Attach Media',
    context: 'Alex supervisaba a Darío',
  },
  {
    quote:
      'Alex es un profesional SEO con gran conocimiento técnico y sentido crítico. Tuvimos la oportunidad de optimizar un sitio enfocado en una vertical complicada como lo es banca. Se enfoca en las necesidades del negocio y en conjunto desarrollamos una estrategia de posicionamiento orgánico efectiva. También debo destacar su compromiso y la forma profesional en que lleva sus proyectos.',
    name: 'Miguel Huahuala',
    role: 'Content Lead en Scotiabank',
    context: 'Miguel trabajó con Alex en distintas empresas',
  },
  {
    quote:
      'Alex tiene un gran manejo y análisis SEO orientado a los resultados en posicionamiento. Así mismo, su compromiso y orientación al servicio nos dio seguridad en cada etapa del proyecto.',
    name: 'Alexis Pinedo',
    role: 'Product Manager en LeaseIn',
    context: 'Alex fue proveedor de Alexis',
  },
];
---

<section style="background: #fff; padding: 5rem 0">
  <div class="max-w-5xl mx-auto px-6 reveal">
    <div style={rule} />

    <div style="padding-top: 3.5rem; margin-bottom: 3rem">
      <Eyebrow>Testimonios</Eyebrow>
      <h2 style="font-size: clamp(2rem, 4vw, 3rem); font-weight: 700; letter-spacing: -0.04em; color: #0d1f3c; margin: 0.5rem 0 0; line-height: 1.08; max-width: 24ch">
        Lo que dicen quienes trabajaron conmigo.
      </h2>
    </div>

    <div class="grid md:grid-cols-2 gap-6">
      {testimonials.map((t) => (
        <div class="testimonial-glass reveal-stagger">
          <div style="font-size: 2.75rem; color: rgba(21,96,189,0.18); line-height: 1; font-family: Georgia, serif">"</div>
          <p style="font-size: 1rem; line-height: 1.75; color: rgba(13,31,60,0.75); margin: 0.5rem 0 1.5rem">
            {t.quote}
          </p>
          <div style="display: flex; align-items: center; gap: 0.85rem">
            <div style="width: 42px; height: 42px; border-radius: 50%; background: linear-gradient(135deg, #1560bd 0%, #0d4a9e 100%); display: flex; align-items: center; justify-content: center; flex-shrink: 0">
              <span style="color: #fff; font-weight: 700; font-size: 0.9rem">{t.name.charAt(0)}</span>
            </div>
            <div style="display: flex; flex-direction: column; gap: 0.15rem">
              <span style="font-size: 0.9rem; font-weight: 700; color: #0d1f3c">{t.name}</span>
              <span style="font-size: 0.75rem; color: rgba(21,96,189,0.6); font-weight: 500">{t.role}</span>
            </div>
          </div>
        </div>
      ))}
    </div>
  </div>
</section>

<style is:global>
  .testimonial-glass {
    position: relative;
    overflow: hidden;
    border-radius: 1.25rem;
    padding: 2rem;
    display: flex;
    flex-direction: column;

    background: linear-gradient(135deg, rgba(21,96,189,0.06) 0%, rgba(21,96,189,0.02) 50%, rgba(124,58,237,0.04) 100%);
    border: 1px solid rgba(21,96,189,0.14);
    box-shadow:
      0 4px 24px rgba(21,96,189,0.06),
      inset 0 1px 0 rgba(255,255,255,0.8);

    background-image:
      radial-gradient(circle, rgba(21,96,189,0.18) 1px, transparent 1px),
      linear-gradient(135deg, rgba(21,96,189,0.06) 0%, rgba(21,96,189,0.02) 50%, rgba(124,58,237,0.04) 100%);
    background-size: 20px 20px, 100% 100%;
    background-position: 0 0, 0 0;
  }

  .testimonial-glass::before {
    content: '';
    position: absolute;
    inset: 0;
    background: rgba(255,255,255,0.55);
    pointer-events: none;
    border-radius: inherit;
  }

  .testimonial-glass > * {
    position: relative;
    z-index: 1;
  }
</style>
