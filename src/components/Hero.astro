---
import Button from './Button.astro';
import IconArrowRight from './IconArrowRight.astro';
import { getImage } from 'astro:assets';
import serpImage from '../assets/serp_image.webp';

const serpImageMetadata = await getImage({ src: serpImage, width: 120, height: 120, format: 'webp' });
const serpImageSrc = serpImageMetadata.src;
---

<section style="padding-top: 10rem; padding-bottom: 0; background: #fff">
  <div class="max-w-5xl mx-auto px-6">

    <div style="margin-bottom: 3.5rem">
      <h1 class="reveal" style="font-size: clamp(2.75rem, 6vw, 4.5rem); font-weight: 700; line-height: 1.02; letter-spacing: -0.04em; color: #0d1f3c; margin: 0 0 1.75rem; max-width: 14ch">
        Tu tienda Shopify{" "}
        <em style="font-style: normal; color: #1560bd">merece ser encontrada.</em>
      </h1>
      <p class="reveal" style="font-size: 1.1rem; line-height: 1.7; color: rgba(13,31,60,0.55); margin: 0 0 2.5rem; max-width: 36ch">
        Auditorías técnicas y estrategia de catálogo para ecommerce. Sin paquetes genéricos.
      </p>
      <div class="reveal">
        <Button href="/contacto">
          Consulta gratuita <IconArrowRight />
        </Button>
      </div>
    </div>

  </div>

  <div class="reveal hero-visuals" style="max-width: 1100px; margin: 0 auto; padding: 0 1.5rem 5rem; position: relative">

    <div class="hero-serp">
      <svg viewBox="0 0 600 208" xmlns="http://www.w3.org/2000/svg" style="width: 100%; height: auto; display: block">
        <defs>
          <clipPath id="imgClip">
            <rect x="460" y="24" width="120" height="120" rx="8" />
          </clipPath>
        </defs>

        <!-- White background -->
        <rect width="600" height="208" fill="#fff" />

        <!-- Favicon + brand name + overflow menu -->
        <circle cx="34" cy="30" r="9" fill="#1560bd" />
        <text x="34" y="34" font-size="10" fill="#fff" font-family="DM Sans, sans-serif" font-weight="700" text-anchor="middle">G</text>
        <text x="52" y="34" font-size="14" fill="#202124" font-family="DM Sans, sans-serif" font-weight="700">GunplaStore MX</text>
        <circle cx="426" cy="27" r="1.6" fill="#5f6368" />
        <circle cx="426" cy="32" r="1.6" fill="#5f6368" />
        <circle cx="426" cy="37" r="1.6" fill="#5f6368" />

        <!-- URL breadcrumb -->
        <text x="30" y="58" font-size="13" fill="#188038" font-family="DM Sans, sans-serif" font-weight="400">gunplastore.mx › Model Kits › Gundam › High Grade</text>

        <!-- Title link -->
        <text x="30" y="88" font-size="19" fill="#1a0dab" font-family="DM Sans, sans-serif" font-weight="500">HG RGC-83 GM Cannon II - GunplaStore MX</text>

        <!-- Rating stars + review count + price -->
        <text x="30" y="108" font-size="14" letter-spacing="2" fill="#fbbc04" font-family="DM Sans, sans-serif">★★★★★</text>
        <text x="118" y="108" font-size="12" fill="#70757a" font-family="DM Sans, sans-serif" font-weight="500">4.9 · 1,247 reseñas · $1,450 MXN</text>

        <!-- Description snippet -->
        <text x="30" y="132" font-size="13" fill="#4d5156" font-family="DM Sans, sans-serif" font-weight="400">
          <tspan x="30" dy="0">Model kit Bandai High Grade escala 1/144. RGC-83 GM Cannon II</tspan>
          <tspan x="30" dy="18">de Mobile Suit Gundam 0083 Stardust Memory. Incluye cañón,</tspan>
          <tspan x="30" dy="18">shield, beam saber y base de exhibición. Envío 24-48h a todo México.</tspan>
        </text>

        <!-- Product image -->
        <image href={serpImageSrc} x="460" y="24" width="120" height="120" clip-path="url(#imgClip)" preserveAspectRatio="xMidYMid slice" />

      </svg>
    </div>

    <div class="hero-chat">
      <div class="chat-header">
        <svg class="chat-logo" width="24" height="24" viewBox="-10 -10 320 320" fill="#ececec" xmlns="http://www.w3.org/2000/svg"><path d="m297.06 130.97c7.26-21.79 4.76-45.66-6.85-65.48-17.46-30.4-52.56-46.04-86.84-38.68-15.25-17.18-37.16-26.95-60.13-26.81-35.04-.08-66.13 22.48-76.91 55.82-22.51 4.61-41.94 18.7-53.31 38.67-17.59 30.32-13.58 68.54 9.92 94.54-7.26 21.79-4.76 45.66 6.85 65.48 17.46 30.4 52.56 46.04 86.84 38.68 15.24 17.18 37.16 26.95 60.13 26.8 35.06.09 66.16-22.49 76.94-55.86 22.51-4.61 41.94-18.7 53.31-38.67 17.57-30.32 13.55-68.51-9.94-94.51zm-120.28 168.11c-14.03.02-27.62-4.89-38.39-13.88.49-.26 1.34-.73 1.89-1.07l63.72-36.8c3.26-1.85 5.26-5.32 5.24-9.07v-89.83l26.93 15.55c.29.14.48.42.52.74v74.39c-.04 33.08-26.83 59.9-59.91 59.97zm-128.84-55.03c-7.03-12.14-9.56-26.37-7.15-40.18.47.28 1.3.79 1.89 1.13l63.72 36.8c3.23 1.89 7.23 1.89 10.47 0l77.79-44.92v31.1c.02.32-.13.63-.38.83l-64.41 37.19c-28.69 16.52-65.33 6.7-81.92-21.95zm-16.77-139.09c7-12.16 18.05-21.46 31.21-26.29 0 .55-.03 1.52-.03 2.2v73.61c-.02 3.74 1.98 7.21 5.23 9.06l77.79 44.91-26.93 15.55c-.27.18-.61.21-.91.08l-64.42-37.22c-28.63-16.58-38.45-53.21-21.95-81.89zm221.26 51.49-77.79-44.92 26.93-15.54c.27-.18.61-.21.91-.08l64.42 37.19c28.68 16.57 38.51 53.26 21.94 81.94-7.01 12.14-18.05 21.44-31.2 26.28v-75.81c.03-3.74-1.96-7.2-5.2-9.06zm26.8-40.34c-.47-.29-1.3-.79-1.89-1.13l-63.72-36.8c-3.23-1.89-7.23-1.89-10.47 0l-77.79 44.92v-31.1c-.02-.32.13-.63.38-.83l64.41-37.16c28.69-16.55 65.37-6.7 81.91 22 6.99 12.12 9.52 26.31 7.15 40.1zm-168.51 55.43-26.94-15.55c-.29-.14-.48-.42-.52-.74v-74.39c.02-33.12 26.89-59.96 60.01-59.94 14.01 0 27.57 4.92 38.34 13.88-.49.26-1.33.73-1.89 1.07l-63.72 36.8c-3.26 1.85-5.26 5.31-5.24 9.06l-.04 89.79zm14.63-31.54 34.65-20.01 34.65 20v40.01l-34.65 20-34.65-20z"/></svg>
        <span class="chat-label">ChatGPT</span>
      </div>

      <div class="chat-user-msg">
            <div class="chat-bubble-user">
              <p>¿Dónde comprar HG RGC-83 GM Cannon II en México?</p>
            </div>
          </div>

          <div class="chat-typing" id="chat-typing">
            <span></span><span></span><span></span>
          </div>

          <div class="chat-ai-msg" id="chat-ai-msg">
            <div class="chat-bubble-ai">
              <p>Te recomiendo <span class="chat-link">GunplaStore MX ↗</span>, tienen el catálogo más completo de Bandai con escalas HG, MG, RG y PG. Envío a todo México en 24-48h y precios competitivos.</p>
            </div>
          </div>
    </div>

  </div>
</section>

<style is:global>
  .hero-visuals {
    position: relative;
    min-height: 380px;
  }
  .hero-serp {
    width: 54%;
    border-radius: 1rem;
    overflow: hidden;
    border: 1px solid rgba(21,96,189,0.10);
    box-shadow: 0 20px 60px rgba(21,96,189,0.10);
    background: #fff;
    z-index: 1;
  }
  .hero-chat {
    position: absolute;
    top: 130px;
    right: 0;
    width: 54%;
    background: #212121;
    border-radius: 1rem;
    padding: 1.25rem;
    box-shadow: 0 20px 60px rgba(0,0,0,0.28);
    border: 1px solid rgba(255,255,255,0.08);
    z-index: 2;
  }
  .chat-header {
    display: flex;
    align-items: center;
    gap: 0.5rem;
    margin-bottom: 1rem;
  }
  .chat-logo {
    flex-shrink: 0;
  }
  .chat-label {
    font-size: 0.7rem;
    font-weight: 600;
    color: #b4b4b4;
    letter-spacing: 0.02em;
  }
  .chat-user-msg {
    display: flex;
    justify-content: flex-end;
    margin-bottom: 0.75rem;
    opacity: 0;
    animation: chatFadeIn 0.4s ease-out 0.3s forwards;
  }
  .chat-bubble-user {
    background: #2f2f2f;
    border-radius: 12px 12px 4px 12px;
    padding: 0.55rem 0.8rem;
    max-width: 85%;
  }
  .chat-bubble-user p {
    font-size: 0.78rem;
    color: #ececec;
    margin: 0;
    line-height: 1.5;
  }
  .chat-typing {
    display: flex;
    justify-content: flex-start;
    gap: 0.35rem;
    padding: 0.4rem 0;
    opacity: 0;
    animation: chatFadeIn 0.3s ease-out 0.7s forwards, chatFadeOut 0.3s ease-out 2s forwards;
  }
  .chat-typing span {
    width: 6px;
    height: 6px;
    border-radius: 50%;
    background: #565869;
    animation: chatBounce 1.2s ease-in-out infinite;
  }
  .chat-typing span:nth-child(2) { animation-delay: 0.15s; }
  .chat-typing span:nth-child(3) { animation-delay: 0.3s; }
  .chat-ai-msg {
    display: flex;
    justify-content: flex-start;
    opacity: 0;
    animation: chatFadeIn 0.5s ease-out 2.1s forwards;
  }
  .chat-bubble-ai {
    padding: 0.55rem 0.8rem 0;
    max-width: 92%;
    padding-right: 0;
  }
  .chat-bubble-ai p {
    font-size: 0.78rem;
    color: #ececec;
    margin: 0;
    line-height: 1.5;
  }
  .chat-link {
    text-decoration: underline;
    text-underline-offset: 2px;
  }

  @keyframes chatFadeIn {
    from { opacity: 0; transform: translateY(6px); }
    to { opacity: 1; transform: translateY(0); }
  }
  @keyframes chatFadeOut {
    from { opacity: 1; }
    to { opacity: 0; height: 0; padding: 0; margin: 0; overflow: hidden; }
  }
  @keyframes chatBounce {
    0%, 80%, 100% { transform: scale(0.6); opacity: 0.4; }
    40% { transform: scale(1); opacity: 1; }
  }

  @media (max-width: 900px) {
    .hero-visuals {
      min-height: auto;
    }
    .hero-serp {
      width: 100%;
    }
    .hero-chat {
      position: relative;
      top: 0;
      right: 0;
      width: 100%;
      margin-top: 1.5rem;
    }
  }
  @media (prefers-reduced-motion: reduce) {
    .chat-user-msg, .chat-ai-msg { opacity: 1; animation: none; }
    .chat-typing { display: none; }
    .chat-typing span { animation: none; }
  }
</style>