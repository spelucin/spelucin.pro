---
interface Props {
  title?: string;
  fullwidth?: boolean;
}
const { title = "zsh - shopify-seo", fullwidth = false } = Astro.props;
---

<div class:list={["terminal-window", { "terminal-fullwidth": fullwidth }]}>
  <div class="terminal-header">
    <div class="terminal-dot red"></div>
    <div class="terminal-dot yellow"></div>
    <div class="terminal-dot green"></div>
    <span class="terminal-title">{title}</span>
  </div>
  <slot />
</div>

<style is:global>
  .terminal-window {
    background: #0d141e;
    border-radius: 8px;
    border: 1px solid rgba(21,96,189,0.15);
    box-shadow: 0 20px 48px rgba(21,96,189,0.12);
    font-family: ui-monospace, SFMono-Regular, Menlo, Monaco, Consolas, monospace;
    font-size: 0.78rem;
    color: #e2e8f0;
    overflow: hidden;
    width: 100%;
  }
  .terminal-fullwidth {
    width: 100%;
    font-size: 0.95rem;
  }
  .terminal-header {
    background: #151d2a;
    padding: 0.55rem 0.75rem;
    display: flex;
    align-items: center;
    gap: 0.35rem;
    border-bottom: 1px solid rgba(21,96,189,0.08);
  }
  .terminal-dot {
    width: 10px;
    height: 10px;
    border-radius: 50%;
  }
  .terminal-dot.red { background: #ef4444; }
  .terminal-dot.yellow { background: #eab308; }
  .terminal-dot.green { background: #22c55e; }
  .terminal-title {
    margin-left: 0.5rem;
    font-size: 0.65rem;
    font-weight: 600;
    color: rgba(21,96,189,0.5);
    letter-spacing: 0.05em;
  }
  .terminal-body {
    padding: 1.25rem;
    line-height: 1.6;
    min-height: 290px;
    text-align: left;
  }
  .terminal-fullwidth .terminal-body {
    padding: 2rem clamp(1.25rem, 4vw, 3rem);
    min-height: 380px;
    font-size: 0.95rem;
  }
  .term-sticky {
    position: sticky;
    top: 120px;
  }
  .term-line {
    margin: 0 0 0.5rem;
    opacity: 0;
    transform: translateY(4px);
    animation: termFadeIn 0.35s ease-out forwards;
  }
  .term-prompt {
    color: #38bdf8;
    font-weight: 700;
    user-select: none;
    margin-right: 0.25rem;
  }
  .term-info { color: #60a5fa; font-weight: 500; }
  .term-warning { color: #fbbf24; font-weight: 500; }
  .term-success { color: #34d399; font-weight: 500; }
  .term-bar {
    color: #38bdf8;
    font-weight: 600;
    letter-spacing: -1px;
  }
  .term-pct {
    color: rgba(226,232,240,0.55);
    margin-left: 0.3rem;
  }
  .term-spinner::before {
    content: '⠋';
    display: inline-block;
    width: 1ch;
    color: #38bdf8;
    margin-right: 0.4rem;
    animation: brailleSpin 0.8s steps(1) infinite;
  }
  @keyframes brailleSpin {
    0% { content: '⠋'; }
    10% { content: '⠙'; }
    20% { content: '⠹'; }
    30% { content: '⠸'; }
    40% { content: '⠼'; }
    50% { content: '⠴'; }
    60% { content: '⠦'; }
    70% { content: '⠧'; }
    80% { content: '⠇'; }
    90% { content: '⠏'; }
    100% { content: '⠋'; }
  }
  @keyframes termFadeIn {
    to { opacity: 1; transform: translateY(0); }
  }
  .term-delay-1 { animation-delay: 0.2s; }
  .term-delay-2 { animation-delay: 1.0s; }
  .term-delay-3 { animation-delay: 1.8s; }
  .term-delay-4 { animation-delay: 2.6s; }
  .term-delay-5 { animation-delay: 3.4s; }
  .term-delay-6 { animation-delay: 4.2s; }
  .term-delay-7 { animation-delay: 5.0s; }
  .term-delay-8 { animation-delay: 5.8s; }
  .term-delay-9 { animation-delay: 6.6s; }
  .term-delay-10 { animation-delay: 7.4s; }
  .term-delay-11 { animation-delay: 8.2s; }
  .term-delay-12 { animation-delay: 9.0s; }
  .term-delay-13 { animation-delay: 9.8s; }
  .term-delay-14 { animation-delay: 10.6s; }

  @media (max-width: 768px) {
    .term-sticky {
      position: relative !important;
      top: 0 !important;
      margin-top: 2.5rem;
    }
    .terminal-fullwidth .terminal-body {
      padding: 1.25rem;
      font-size: 0.8rem;
    }
  }
</style>
