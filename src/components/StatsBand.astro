---
import { stats, rule } from '../data';
---

<section style="background: #fff; padding: 2.5rem 0">
  <div class="max-w-5xl mx-auto px-6">
    <div style={rule} />
    <div class="reveal-stagger" style="display: flex; flex-wrap: wrap; gap: 3rem; padding-top: 2.5rem">
      {stats.map((s) => (
        <div style="flex: 1 1 140px">
          <div style="font-size: clamp(1.6rem, 3vw, 2.25rem); font-weight: 700; color: #1560bd; letter-spacing: -0.04em; line-height: 1">{s.value}</div>
          <div style="font-size: 0.78rem; color: rgba(13,31,60,0.45); font-weight: 500; margin-top: 0.4rem; line-height: 1.4">{s.label}</div>
        </div>
      ))}
    </div>
  </div>
</section>